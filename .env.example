# =============================================================================
# Local development
# =============================================================================
BACKEND_PROXY_TARGET=http://127.0.0.1:3001
NEXT_PUBLIC_API_USE_PROXY=1

# Optional: call the API directly instead of the proxy (set NEXT_PUBLIC_API_USE_PROXY=0)
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Optional: enrich rent suggestions with OpenAI (local RAG works without this)
# OPENAI_API_KEY=

# =============================================================================
# Vercel production (recommended: proxy — avoids CORS in the browser)
# Set these in: Vercel → Project → Settings → Environment Variables
# Redeploy after changing BACKEND_PROXY_TARGET (used at build time in next.config)
# =============================================================================
# BACKEND_PROXY_TARGET=https://aarentalmanagementsystembackend.onrender.com
# (one line, no quotes, no spaces or line breaks before/after the URL)
# NEXT_PUBLIC_API_USE_PROXY=1
# Do not set NEXT_PUBLIC_API_BASE_URL when using the proxy.

# =============================================================================
# Vercel production (alternative: direct API — requires backend CORS_ORIGIN)
# =============================================================================
# NEXT_PUBLIC_API_BASE_URL=https://aarentalmanagementsystembackend.onrender.com
# NEXT_PUBLIC_API_USE_PROXY=0
